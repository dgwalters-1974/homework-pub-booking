# ── Secrets ──────────────────────────────────────────────────────────
# NEVER commit .env — it has your API keys.
.env
.env.local
.env.*.local

# ── Session artifacts ────────────────────────────────────────────────
# Default-stored sessions (~/Library/Application Support/...) are not committed.
# A repo-local `sessions/` directory IS committed — the rubric expects session
# artefacts at submission time so the LLM judge can verify Ex9 citations.
demo_sessions_*/
*.session.json

# Audio captured during Ex8 voice mode — never commit (contains the user's voice).
# Trace events in logs/trace.jsonl already capture the transcribed text.
sessions/**/*.wav
sessions/**/*.mp3
sessions/**/*.m4a
sessions/**/*.flac
sessions/**/*.ogg
sessions/**/*.opus

# ── Python standard ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env.bak/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
*.egg-info/
build/
dist/
.coverage
htmlcov/

# ── Rasa ─────────────────────────────────────────────────────────────
# Generated models, should not be in source control.
rasa_project/models/
rasa_project/.rasa/
rasa_project/results/

# ── OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Answers held locally but not submitted ───────────────────────────
# If you keep working notes, put them under answers-local/ instead.
answers-local/

# ── Uploads for grader ───────────────────────────────────────────────
# The grader's private tests are materialised here at CI time.
# They should never be checked in by students.
tests/private/*
!tests/private/.gitkeep

# ── uv ───────────────────────────────────────────────────────────────
# uv.lock IS committed on purpose (reproducible installs). Do not add it here.

# ── Educator solutions (NEVER COMMIT) ────────────────────────────────
# The `solution/` directory contains reference implementations of every
# exercise. It lives in the educator's private workspace only. Students
# never see it.
#
# If you're a student looking at .gitignore: `solution/` does not exist
# in the public repo. We generate it on the educator's machine from a
# sibling private repo (homework-pub-booking-solutions) that isn't open.
solution/
educator/_scratch/

# ── Obsidian guide ────────────────────────────────────────────────────
obsidian-guide/
CLAUDE.md

# ── Claude Code per-project settings ─────────────────────────────────
# Local Claude Code settings + any in-repo agent state. The persistent
# memory store lives in ~/.claude/projects/.../memory/ (outside the repo)
# and is never visible to git, but ignore .claude/ defensively.
.claude/

# ── Personal notes (never commit) ────────────────────────────────────
# Working notes, bug diagnoses, draft answers, etc. — anything you want
# to keep alongside the code without publishing.
notes/